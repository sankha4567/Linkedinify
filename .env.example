# ---------------------------------------------------------------
# Copy this file to .env.local and fill in the real values.
# Do NOT commit .env.local — it is in .gitignore.
# ---------------------------------------------------------------

# --- Convex ---------------------------------------------------
# Created automatically when you run `npx convex dev` for the
# first time and pick / create a project.
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Public Convex URL (safe to expose to the browser)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# --- Clerk ----------------------------------------------------
# Get these from https://dashboard.clerk.com  ->  API Keys
CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api.clerk.accounts.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>
